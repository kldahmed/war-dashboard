{
  "name": "war-news-dashboard",
  "version": "1.0.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "leaflet": "^1.9.4",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-scripts": "5.0.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "server": "node server.js",
    "dev": "concurrently -n API,CRA -c cyan,green \"node server.js\" \"react-scripts start\"",
    "migrate:up": "node backend/db/migrate.js up",
    "migrate:down": "node backend/db/migrate.js down",
    "seed": "node backend/db/seed.js",
    "ingest:rss": "node backend/jobs/run-ingestion.js",
    "smoke:backend": "node scripts/smoke-checks.js",
    "check:integration:sprint1": "node scripts/integration-sprint1.js",
    "check:vercel:wave1": "node scripts/vercel-wave1-check.js",
    "optimizer:run": "node backend/jobs/auto-optimize.js",
    "sitrep:run": "node backend/jobs/generate-sitrep.js",
    "sitrep:force": "node backend/jobs/generate-sitrep.js --force"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
