# ──────────────────────────────────────────────────────────────────────
# war-dashboard — Required Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (for local dev) and set real values.
# In Vercel: add these via Project → Settings → Environment Variables.
# NEVER commit real keys to version control.

# Anthropic Claude API key — server-side ONLY (used by /api/claude.js)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection string for Sprint 1 backend storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/war_dashboard

# Soft launch production baseline:
# REACT_APP_FEED_MODE=stored
# REACT_APP_FEED_FALLBACK=false
# REACT_APP_PRODUCTION_VERIFY_MODE=true
# FEED_MODE=stored
# FEED_FALLBACK_ENABLED=false

# Frontend adapter mode (legacy|stored). Local default can stay legacy.
REACT_APP_FEED_MODE=legacy

# If stored mode fails, fallback to legacy /api/claude.
REACT_APP_FEED_FALLBACK=true

# Disable silent fallback when verifying the stored production path.
REACT_APP_PRODUCTION_VERIFY_MODE=false

# Backend mode flags (read by local server).
FEED_MODE=legacy
FEED_FALLBACK_ENABLED=true

# RSS ingestion runtime settings
RSS_REQUEST_TIMEOUT_MS=15000
INGESTION_DEFAULT_LIMIT=20

# Auth settings
AUTH_JWT_ACCESS_SECRET=replace_with_long_random_access_secret
AUTH_JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
AUTH_JWT_ACCESS_EXPIRES=15m
AUTH_JWT_REFRESH_EXPIRES=7d
AUTH_REFRESH_MAX_AGE_MS=604800000
AUTH_COOKIE_SECURE=false
